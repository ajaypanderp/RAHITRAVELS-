rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin-managed content — fully public read/write
    // (admin-app.html has no Firebase Auth, password protected instead)
    match /cars/{docId} { allow read, write: if true; }
    match /categories/{docId} { allow read, write: if true; }
    match /gallery/{docId} { allow read, write: if true; }
    match /hero_images/{docId} { allow read, write: if true; }
    match /places/{docId} { allow read, write: if true; }
    match /place_sections/{docId} { allow read, write: if true; }
    match /api_keys/{docId} { allow read, write: if true; }

    // Settings (WhatsApp configuration)
    match /settings/{docId} { allow read, write: if true; }

    // Bookings — admin reads/deletes ALL; users create their own
    match /bookings/{docId} {
      allow read, write: if true;
    }
    
    // Users — read all (for admin); write only own profile
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Visitors — anyone can read/write (tracking & analytics)
    match /visitors/{docId} {
      allow read, write: if true;
    }
  }
}
